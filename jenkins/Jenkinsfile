pipeline {
    agent any 
    
    stages {
        stage('Tests') {
            agent {
                docker {
                    image 'python:3.11-slim'
                    reuseNode true
                }
            }
            steps {
                sh '''
                    echo "Python version:"
                    python3 --version
                    
                    echo "Installing dependencies..."
                    pip install --no-cache-dir -r requirements.txt
                    
                    echo "Running tests..."
                    pytest -v
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                script {
                    sh "docker build -t python-api:latest ."
                }
            }
        }
        
        stage('Deploy Container') {
            steps {
                script {
                    sh "docker rm -f my-python-api || true"
                    sh "docker run -d --name my-python-api -p 8000:8000 python-api:latest"
                }
            }
        }
        
        stage('Health Check') {
            steps {
                timeout(time: 10, unit: 'SECONDS') {
                    retry(5) {
                        script {
                            sleep(time: 5, unit: 'SECONDS')
                            sh 'docker exec my-python-api python3 -c "import urllib.request; print(urllib.request.urlopen(\'http://localhost:8000/health\').read())"'
                        }
                    }
                }
            }
        }
    }
    
    post { 
        always {
            echo "Pipeline finished execution."
            sh "docker image prune -f || true"
        }
        failure { 
            echo 'Something failed :( Pipeline execution failed.'
        }
        success {
            echo 'Everything passed successfully! API is up and running.'
        }
    }
}